{
  "version": 2,
  "builds": [
    {
      "src": "loginAuthBackend.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS, PUT, DELETE",
        "Access-Control-Allow-Headers": "Content-Type"
      },
      "src": "/api/(.*)",
      "dest": "loginAuthBackend.js"
    }
  ]
}